{
  "name": "scriptplayer-plus",
  "version": "0.2.7",
  "description": "ScriptPlayer+ - Funscript video player with Handy, Intiface, and FunOSR support",
  "private": true,
  "author": "sioaeko <grade0422@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "main": "dist-electron/main.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "electron:dev": "vite build --mode development && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:linux": "vite build && electron-builder --linux",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:all": "vite build && electron-builder --win --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "25.1.8",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.scriptplayerplus.app",
    "productName": "ScriptPlayerPlus",
    "icon": "public/icon.png",
    "asarUnpack": [
      "node_modules/@serialport/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "afterPack": "scripts/after-pack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "sioaeko",
        "repo": "scriptplayer-plus",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false,
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "ScriptPlayerPlus-v${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ScriptPlayer+",
      "uninstallDisplayName": "ScriptPlayer+",
      "runAfterFinish": true,
      "artifactName": "ScriptPlayerPlus Setup ${version}.${ext}"
    },
    "mac": {
      "identity": "-",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.entertainment",
      "artifactName": "ScriptPlayerPlus-${version}-${arch}-mac.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "AudioVideo",
      "synopsis": "Funscript video player with Handy, Intiface, and FunOSR support",
      "artifactName": "ScriptPlayerPlus-${version}-linux-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "portable": {
      "artifactName": "ScriptPlayer+-${version}-portable.${ext}"
    }
  }
}
